import Http from '../../transport/http/http'
import Logger from '../../pkg/logger'
import Usecase from './usecase/usecase'
import Handler from './delivery/http/handler'
import { VerifyAuth } from '../../transport/http/middleware/verifyAuth'
import { Config } from '../../config/config.interface'
import Jwt from '../../pkg/jwt'
import { Connection } from '../../database/sequelize/interface'
import {{pascalCase repository}}Repository from '../../database/repository/{{camelCase repository}}/repository'
import Sequelize from '../../database/sequelize/sequelize'
import { {{properCase name}}HttpContract as C } from './delivery/http/contract'

class {{properCase name}} {
    private usecase: Usecase

    constructor(
        private logger: Logger,
        private config: Config,
        connection: Connection
    ) {
        const schema = Sequelize.Models(connection)
        const {{camelCase repository}}Repository = new {{pascalCase repository}}Repository(logger, schema)
        this.usecase = new Usecase(logger, {{camelCase repository}}Repository)
    }

    public RunHttp(http: Http) {
        const handler = new Handler(this.logger, http, this.usecase)
        this.httpPublic(handler, http)
        this.httpPrivate(handler, http)
        return this
    }

    private httpPublic(handler: Handler, http: Http) {
        const Router = http.Router()

        Router.get('/', handler.Fetch, {
            query: C.QueryList,
            response: {
                200: C.ResponseList200,
            },
            detail: { summary: 'List {{camelCase name}} (public)' },
        })
        Router.get('/:id', handler.Show, {
            params: C.ParamsId,
            response: {
                200: C.ResponseShow200,
            },
            detail: { summary: 'Get {{camelCase name}} by id (public)' },
        })

        http.SetRouter('/v1/public/{{camelCase name}}', Router, { tags: '{{properCase name}}' })
    }

    public httpPrivate(handler: Handler, http: Http) {
        const Router = http.Router()
        const jwt = new Jwt(this.config.jwt.access_key)
        const auth = VerifyAuth(jwt)

        Router.onBeforeHandle(auth).get('/', handler.Fetch, {
            query: C.QueryList,
            response: {
                200: C.ResponseList200,
            },
            detail: { summary: 'List {{camelCase name}} (protected)' },
        })
        Router.onBeforeHandle(auth).post('/', handler.Store, {
            body: C.BodyCreate,
            response: {
                201: C.ResponseCreate201,
            },
            detail: { summary: 'Create {{camelCase name}} (protected)' },
        })
        Router.onBeforeHandle(auth).patch('/:id', handler.Update, {
            params: C.ParamsId,
            body: C.BodyUpdate,
            response: {
                200: C.ResponseUpdate200,
            },
            detail: { summary: 'Update {{camelCase name}} (protected)' },
        })
        Router.onBeforeHandle(auth).delete('/:id', handler.Delete, {
            params: C.ParamsId,
            response: {
                200: C.ResponseDelete200,
            },
            detail: { summary: 'Delete {{camelCase name}} (protected)' },
        })

        http.SetRouter('/v1/{{camelCase name}}', Router, { tags: '{{properCase name}}' })
    }
}

export default {{properCase name}}
