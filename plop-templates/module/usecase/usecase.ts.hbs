        private logger: Logger{{#each repositories}},
        private {{camelCase this}}Repository: {{pascalCase this}}Repository{{/each}}
    ) {}

    public async Fetch(_request: RequestParams<RequestQueryFetch>) {
        throw new Error(
            statusCode.INTERNAL_SERVER_ERROR,
