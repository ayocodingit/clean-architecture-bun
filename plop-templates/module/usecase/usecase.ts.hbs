import { RequestParams } from '../../../helpers/requestParams'
import Logger from '../../../pkg/logger'
import { RequestBody, RequestQueryFetch, Update } from '../entity/interface'
import statusCode from '../../../pkg/statusCode'
import Error from '../../../pkg/error'
{{#each repositories}}
import {{pascalCase this}}Repository from '../../../database/repository/{{camelCase this}}/repository'
{{/each}}

class Usecase {
{{#if (eq (repoCount repositories) 1)}}
    constructor(
        private logger: Logger,
        private {{camelCase (lookup repositories 0)}}Repository: {{pascalCase (lookup repositories 0)}}Repository
    ) {}

    public async Fetch(request: RequestParams<RequestQueryFetch>) {
        const result = await this.{{camelCase (lookup repositories 0)}}Repository.Fetch(request)
        return result
    }

    public async Show(id: number) {
        const result = await this.{{camelCase (lookup repositories 0)}}Repository.GetById(id)
        if (!result) {
            throw new Error(statusCode.NOT_FOUND, statusCode[statusCode.NOT_FOUND])
        }
        return result
    }

    public async Store(body: RequestBody) {
        return this.{{camelCase (lookup repositories 0)}}Repository.Store(body)
    }

    public async Update(id: number, body: Update) {
        await this.Show(id)
        return this.{{camelCase (lookup repositories 0)}}Repository.Update(id, body)
    }

    public async Delete(id: number) {
        await this.Show(id)
        return this.{{camelCase (lookup repositories 0)}}Repository.Delete(id)
    }
{{else}}
