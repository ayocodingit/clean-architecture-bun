import { RequestParams } from '../../../helpers/requestParams'
import Logger from '../../../pkg/logger'
import { RequestBody, RequestQueryFetch, Update } from '../entity/interface'
import {{pascalCase repository}}Repository from '../../../database/repository/{{camelCase repository}}/{{ camelCase repository }}'
import statusCode from '../../../pkg/statusCode'
import Error from '../../../pkg/error'

class Usecase {
    constructor(private logger: Logger, private {{camelCase repository}}Repository: {{pascalCase repository}}Repository) { }

    public async Fetch(request: RequestParams<RequestQueryFetch>) {
        const result = await this.{{camelCase repository}}Repository.Fetch(request)
        return result
    }

    public async Show(id: number) {
        const result = await this.{{camelCase repository}}Repository.GetById(id)
        if (!result) {
            throw new Error(statusCode.NOT_FOUND, statusCode[statusCode.NOT_FOUND])
        }
        return result
    }

    public async Store(body: RequestBody) {
        return this.{{camelCase repository}}Repository.Store(body)
    }

    public async Update(id: number, body: Update) {
        await this.Show(id)
        return this.{{camelCase repository}}Repository.Update(id, body)
    }

    public async Delete(id: number) {
        await this.Show(id)
        return this.{{camelCase repository}}Repository.Delete(id)
    }
}

export default Usecase
