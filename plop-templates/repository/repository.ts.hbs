} from './types'

/**
 * Repository {{pascalCase repository}}: layer akses data (Sequelize).
 * Fetch pakai RequestParams (helpers) + {{pascalCase repository}}Filter (custom filter di types).
 */
class {{pascalCase repository}}Repository {
    constructor(private logger: Logger, private schema: Schema) {}

    public async Fetch(params: RequestParams<{{pascalCase repository}}Filter>) {
        const { count, rows } = await this.schema.{{camelCase repository}}.findAndCountAll({
            limit: params.per_page,
            offset: params.offset,
